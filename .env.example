# Frontend
# Local dev usually leaves this empty so Vite can proxy /api to the backend.
VITE_API_BASE_URL=

# Backend
TECHTRACE_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
TECHTRACE_ARXIV_API_URL=https://export.arxiv.org/api/query
TECHTRACE_ARXIV_TIMEOUT_SEC=20
TECHTRACE_SERPAPI_SEARCH_URL=https://serpapi.com/search.json
TECHTRACE_GOOGLE_PATENTS_BASE_URL=https://patents.google.com
TECHTRACE_GOOGLE_PATENTS_XHR_URL=https://patents.google.com/xhr/query
TECHTRACE_GOOGLE_PATENTS_TIMEOUT_SEC=20
TECHTRACE_LENS_API_URL=https://api.lens.org/patent/search
TECHTRACE_LENS_TIMEOUT_SEC=25
TECHTRACE_PDF_MAX_PAGES=20
TECHTRACE_PDF_MAX_CHARS=12000
TECHTRACE_ARXIV_FALLBACK_API_URL=http://export.arxiv.org/api/query
TECHTRACE_PUBLIC_WEB_TIMEOUT_SEC=20
TECHTRACE_PUBLIC_WEB_MAX_URLS=5
TECHTRACE_PUBLIC_WEB_MAX_CHARS=12000

# Optional AI enhancement
TECHTRACE_OPENAI_API_KEY=
TECHTRACE_OPENAI_API_URL=https://api.openai.com/v1/responses
TECHTRACE_OPENAI_MODEL=gpt-5
TECHTRACE_OPENAI_TIMEOUT_SEC=30

# Required only when using Lens.org live API
TECHTRACE_LENS_API_KEY=

# Optional but recommended for Google Patents live search via SerpApi
TECHTRACE_GOOGLE_PATENTS_API_KEY=
